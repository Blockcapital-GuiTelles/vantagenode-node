# Secrets — never commit.
.env
.env.local
.env.*.local

# Local node data (never reaches the repo — it's hundreds of GB).
/opt/vantagenode/
data/
*.dat
debug.log
bitcoin/

# ...except the small baked snapshots tier_test handlers read at boot.
# Sub-MB JSON cached from the BL refresher, used by handlers like
# mvrv_test until the live Tier-2 indexer comes online. Real archive
# bitcoin data still excluded via the broader rule above.
!indexer/data/
!indexer/data/*.json

# Build artefacts.
indexer/node_modules/
indexer/dist/
indexer/.tsbuildinfo

# OS / editor cruft.
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Caddy local cache (when running compose locally).
caddy-data/
caddy-config/

# Logs.
*.log
logs/
