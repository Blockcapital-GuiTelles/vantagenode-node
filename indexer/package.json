{
  "name": "vantagenode-indexer",
  "version": "0.1.0",
  "private": true,
  "description": "VantageNode onchain indexer + REST API. Reads bitcoind RPC + ZMQ, persists derived metrics to Postgres, serves /api/metric/<slug>.",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../.env --watch --experimental-strip-types src/server.ts",
    "start": "node --experimental-strip-types src/server.ts",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "pg": "^8.13.0",
    "zeromq": "^6.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.6.0"
  }
}
