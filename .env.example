# Copy this file to .env on the production host. Never commit .env.

# ============================================================
# Bitcoin Core
# ============================================================
# rpcauth = bitcoincore-rpcauth.py output. Generate with:
#   python3 infra/gen-rpcauth.py indexer
# Then paste the printed `rpcauth=...` value below (without the prefix).
BITCOIND_RPCAUTH=indexer:HASHED_VALUE_HERE

# The cleartext password the indexer uses to connect via RPC. Must
# match the password that produced the BITCOIND_RPCAUTH hash above.
BITCOIN_RPC_USER=indexer
BITCOIN_RPC_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ============================================================
# Postgres
# ============================================================
# Strong random secret (use `openssl rand -hex 32`).
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ============================================================
# API auth
# ============================================================
# Shared HMAC secret. The VantageNode app sets this same value in its
# own env so the X-Node-Auth header verifies. Rotate by setting both
# sides at the same time.
NODE_SHARED_SECRET=CHANGE_ME_BEFORE_DEPLOY_use_openssl_rand_hex_32

# ============================================================
# Public hostname for TLS
# ============================================================
# DNS must point this host's public IP. Caddy will auto-provision a
# Let's Encrypt cert on first start.
NODE_HOSTNAME=node.vantagenode.io

# ============================================================
# Observability UI passwords
# ============================================================
# Portainer admin password — bcrypt hash. Generate with:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'YOUR_PASSWORD' | cut -d ':' -f2
PORTAINER_ADMIN_BCRYPT=CHANGE_ME

# Grafana admin password — plain text (read at container start).
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ============================================================
# Tailscale lockdown
# ============================================================
# IP address the Portainer/Grafana/Uptime Kuma host bindings listen on.
# Set to the tailscale-assigned IP so those UIs are reachable ONLY via
# the tailnet. Run on the host: `docker exec tailscaled tailscale ip -4`.
TAILSCALE_IP=100.x.y.z
